{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^.*$" },
        "background": {
          "beginsPattern": "creating an optimized production build|ready - started server",
          "endsPattern": "ready - started server on"
        }
      },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false,
        "clear": true
      },
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
